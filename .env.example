PORT=3001
NODE_ENV=production
DB_PATH=./data/socialmind.db
FRONTEND_URL=https://your-frontend.railway.app

# Canonical production source of truth:
# set these on the backend Railway service as environment variables.
# Local development can use backend/.env (gitignored).

# Meta / Instagram OAuth (required for Instagram automation)
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret

# TikTok OAuth (optional)
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret

# AI
ANTHROPIC_API_KEY=sk-ant-...

# Webhooks
INSTAGRAM_VERIFY_TOKEN=socialmind_verify_2024
TIKTOK_VERIFY_TOKEN=socialmind_tiktok_2024
